# Student Fee Manager - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Session Secret (generate with: openssl rand -base64 64)
SESSION_SECRET="your_session_secret_here"

# PostgreSQL Database (Neon)
PGDATABASE="neondb"
PGHOST="your-neon-host.neon.tech"
PGPORT="5432"
PGUSER="neondb_owner"
PGPASSWORD="your_password"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Razorpay Payment Gateway
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
VITE_RAZORPAY_KEY_ID="your_razorpay_key_id"

# Groq AI API
GROQ_API_KEY="your_groq_api_key"

# Twilio Voice API
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Google Voice (Optional)
GOOGLE_EMAIL="your_email@gmail.com"
GOOGLE_PASSWORD="your_password"

# Public URL (for webhooks - set to your GCP external IP or domain)
PUBLIC_URL="http://your-gcp-ip-or-domain"
